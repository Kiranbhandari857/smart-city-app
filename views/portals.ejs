<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Smart City Hub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        body, html {
            margin: 0;
            padding: 0;
            font-family: 'Inter', -apple-system, sans-serif;
            height: 100%;
        }

        /* Stunning Photographic Background with Dark Overlay */
        .bg-image {
            background-image: linear-gradient(rgba(11, 19, 43, 0.75), rgba(11, 19, 43, 0.95)), 
                              url('https://images.unsplash.com/photo-1449824913935-59a10b8d2000?q=80&w=2070&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            min-height: 100vh;
            display: flex;
            align-items: center;
        }

        /* Layout Styling */
        .hero-text {
            color: white;
            padding-right: 3rem;
        }

        .hero-title {
            font-weight: 800;
            font-size: 4rem;
            letter-spacing: -1.5px;
            margin-bottom: 1.5rem;
            background: linear-gradient(90deg, #ffffff, #a1b0cb);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero-subtitle {
            color: #c5d1e6;
            font-size: 1.25rem;
            line-height: 1.8;
            margin-bottom: 2rem;
        }

        /* Upgraded Glass Cards */
        .portal-card {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 20px;
            padding: 2.5rem;
            text-decoration: none;
            color: white;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 1.5rem;
            margin-bottom: 1.5rem;
            box-shadow: 0 15px 35px rgba(0,0,0,0.2);
        }

        .portal-card:hover {
            transform: translateX(10px);
            background: rgba(255, 255, 255, 0.12);
            border: 1px solid rgba(255, 255, 255, 0.3);
            color: white;
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        }

        .icon-box {
            background: rgba(255, 255, 255, 0.1);
            padding: 1.2rem;
            border-radius: 16px;
            font-size: 2.5rem;
            color: #4facfe;
        }
        
        .admin-icon {
            color: #f6d365;
        }
    </style>
</head>
<body>

    <div class="bg-image">
        <div class="container">
            <div class="row align-items-center">
                
                <div class="col-lg-6 hero-text text-center text-lg-start mb-5 mb-lg-0">
                    <span class="badge bg-primary bg-opacity-25 text-info border border-info px-3 py-2 rounded-pill mb-3">
                        <i class="bi bi-broadcast me-2"></i>Live City Network
                    </span>
                    <h1 class="hero-title">Smarter Cities.<br>Better Lives.</h1>
                    <p class="hero-subtitle">Welcome to the central nervous system of your neighborhood. Report infrastructure issues in real-time, track repair progress, and help city officials build a safer, cleaner environment.</p>
                </div>

                <div class="col-lg-5 offset-lg-1">
                    
                    <a href="/dashboard" class="portal-card">
                        <div class="icon-box">
                            <i class="bi bi-people-fill"></i>
                        </div>
                        <div>
                            <h3 class="fw-bold h4 mb-1">Citizen Portal</h3>
                            <p class="small text-light opacity-75 mb-0">File reports and track resolutions.</p>
                        </div>
                        <i class="bi bi-chevron-right ms-auto fs-4 opacity-50"></i>
                    </a>

                    <a href="/admin" class="portal-card">
                        <div class="icon-box admin-icon">
                            <i class="bi bi-shield-lock-fill"></i>
                        </div>
                        <div>
                            <h3 class="fw-bold h4 mb-1">Admin Vault</h3>
                            <p class="small text-light opacity-75 mb-0">City official dashboard access.</p>
                        </div>
                        <i class="bi bi-chevron-right ms-auto fs-4 opacity-50"></i>
                    </a>

                </div>
            </div>
        </div>
    </div>
<button id="chat-toggle" class="btn btn-primary rounded-circle shadow-lg" style="position: fixed; bottom: 30px; right: 30px; width: 65px; height: 65px; z-index: 1000; background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); border: none;">
        <i class="bi bi-chat-dots-fill fs-3 text-white"></i>
    </button>

    <div id="chat-window" class="card shadow-lg d-none" style="position: fixed; bottom: 110px; right: 30px; width: 350px; border-radius: 20px; overflow: hidden; z-index: 1000; border: 1px solid rgba(255,255,255,0.1);">
        <div class="card-header text-white" style="background: linear-gradient(135deg, #0b132b 0%, #1c2541 100%); border-bottom: none;">
            <h5 class="mb-0 fw-bold"><i class="bi bi-robot me-2"></i>City AI Assistant</h5>
        </div>
        <div id="chat-messages" class="card-body bg-light" style="height: 300px; overflow-y: auto; display: flex; flex-direction: column; gap: 10px;">
            <div class="p-2 bg-primary text-white rounded-3 shadow-sm" style="align-self: flex-start; max-width: 85%;">
                Hello! I am your Smart City AI. How can I help you today?
            </div>
        </div>
        <div class="card-footer bg-white">
            <div class="input-group">
                <input type="text" id="chat-input" class="form-control" placeholder="Ask me anything...">
                <button id="send-btn" class="btn btn-primary"><i class="bi bi-send-fill"></i></button>
            </div>
        </div>
    </div>

    <script>
        const chatToggle = document.getElementById('chat-toggle');
        const chatWindow = document.getElementById('chat-window');
        const chatInput = document.getElementById('chat-input');
        const sendBtn = document.getElementById('send-btn');
        const chatMessages = document.getElementById('chat-messages');

        // Open/Close chat window
        chatToggle.addEventListener('click', () => {
            chatWindow.classList.toggle('d-none');
        });

        // Send Message Function
        async function sendMessage() {
            const message = chatInput.value.trim();
            if (!message) return;

            // 1. Add User message to screen
            chatMessages.innerHTML += `<div class="p-2 bg-white border rounded-3 shadow-sm text-dark" style="align-self: flex-end; max-width: 85%;">${message}</div>`;
            chatInput.value = '';
            chatMessages.scrollTop = chatMessages.scrollHeight;

            // 2. Add loading text
            const loadingId = 'loading-' + Date.now();
            chatMessages.innerHTML += `<div id="${loadingId}" class="p-2 bg-primary bg-opacity-75 text-white rounded-3 shadow-sm small" style="align-self: flex-start; max-width: 85%;">Typing...</div>`;
            chatMessages.scrollTop = chatMessages.scrollHeight;

            // 3. Call your Node backend
            try {
                const response = await fetch('/api/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: message })
                });
                const data = await response.json();
                
                // 4. Remove loading and add AI reply
                document.getElementById(loadingId).remove();
                chatMessages.innerHTML += `<div class="p-2 bg-primary text-white rounded-3 shadow-sm" style="align-self: flex-start; max-width: 85%;">${data.reply}</div>`;
                chatMessages.scrollTop = chatMessages.scrollHeight;
            } catch (err) {
                document.getElementById(loadingId).innerText = "Error connecting to server.";
            }
        }

        // Send on button click or Enter key
        sendBtn.addEventListener('click', sendMessage);
        chatInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') sendMessage();
        });
    </script>
</body>
</html>